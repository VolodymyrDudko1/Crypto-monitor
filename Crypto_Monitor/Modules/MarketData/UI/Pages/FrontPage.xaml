<Page x:Class="Crypto_Monitor.Pages.FrontPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
      xmlns:local="clr-namespace:Crypto_Monitor.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="FrontPage"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      FontSize="20">
    

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/PresentationFramework.Fluent;component/Themes/Fluent.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>



    <Grid>
        <StackPanel Orientation="Vertical">
            <StackPanel.Resources>
                
                <Style TargetType="{x:Type StackPanel}">
                    <Setter Property="Margin" Value="0,20,0,0"/>
                </Style>
            </StackPanel.Resources>
            <TextBlock Text="Look what's on the rise" FontSize="40" VerticalAlignment="Center" FontWeight="Bold" />
            <Grid>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch" >
                <TextBlock Text="Limit:" VerticalAlignment="Center" Margin="0,0,30,0" FontSize="25" ></TextBlock>
                <xctk:IntegerUpDown 
                    Name="numUpDown"
                    Minimum="1"
                    Maximum="20"
                    Increment="1"
                    Value="10"
                    FormatString="N0"
 
                    Background="{DynamicResource ApplicationBackgroundBrush}"
                    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                    />
                <Button x:Name="ApplyButton" Margin="20,0,0,0" Content="Apply"></Button>
            </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBox x:Name="SearchBox" MinWidth="200" Padding="3" Margin="10,0"></TextBox>
                    <Button x:Name="SearchButton" Content="Search" ></Button>
                </StackPanel>
            </Grid>
        </StackPanel>
    </Grid>
</Page>
