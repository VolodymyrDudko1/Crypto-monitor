{
  "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",
  "metadata": [
    {
      "src": [
        {
          "src": ".",
          "files": [
            "Crypto_Monitor.csproj"
          ]
        }
      ],
      "dest": "api"
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "api/**.yml",
          "api/index.md"
        ]
      },
      {
        "files": [
          "docs/**.md",
          "docs/**/toc.yml",
          "toc.yml",
          "*.md"
        ]
      }
    ],
    "output": "_site",
    "template": [
      "modern",
      "default"
    ],
    "globalMetadata": {
      "_appName": "Crypto Monitor API",
      "_appTitle": "Crypto Monitor API Docs",
      "_enableSearch": true
    }
  }
}